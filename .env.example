# Copy to `.env` and fill in to switch from DEMO to LIVE mode.
# Leave unset to keep running locally with the demo role-picker + logged stubs.

# --- Entra app registration (required for live) ---
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
# Must match a Redirect URI on the app registration (Web platform).
# In LIVE mode this MUST be your real https URL — the app refuses to start otherwise.
APP_BASE_URL=http://localhost:4000
# In LIVE mode this MUST be a long random value (the app refuses to start on the
# default). Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- References (Adobe Sign) ---
# The Adobe Sign widget URL references receive to fill out.
REFERENCE_FORM_URL=
# Shared secret Adobe sends back on the completion webhook. REQUIRED in live mode —
# without it the reference-completed webhook rejects every call.
REFERENCE_WEBHOOK_SECRET=

# --- SharePoint target (where completed PDFs are filed) ---
# Get SP_SITE_ID from:  GET /sites/{host}:/sites/{path}   e.g. optimaedcom.sharepoint.com:/sites/HR
SP_SITE_ID=
SP_DRIVE_ID=
SP_BASE_PATH=Onboarding (Automation)/Candidate Folders

# --- Provisioning / mail ---
MAIL_DOMAIN=optimaed.com
MAIL_FROM=hr@optimaed.com

# Microsoft Graph application permissions to grant + admin-consent:
#   Sites.Selected (scoped to the HR site only) — file PDFs
#   User.ReadWrite.All   — create accounts
#   Group.ReadWrite.All  — group membership
#   Mail.Send            — notifications
