{
  "name": "optima-onboarding",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Optima HR onboarding web app — schema-driven forms, candidate-centric data, role-based access provisioning",
  "scripts": {
    "start": "node server.js",
    "seed": "node src/seed.js",
    "seed:config": "node -e \"import('./src/seed.js').then(m => m.seedConfig())\"",
    "backfill:sharepoint": "node src/backfill-sharepoint.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.5",
    "express": "^4.21.2",
    "express-session": "^1.19.0",
    "pdf-lib": "^1.17.1",
    "session-file-store": "^1.5.0"
  }
}
